rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == uid;
      allow delete: if false;
    }

    match /lobby_messages/{msgId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() < 500;
      allow update, delete: if false;
    }

    match /rooms/{roomId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.status == 'open';

      // 보안 하드닝: "로그인하면 누구나 남의 방 수정"(옛 허점)을 막는다.
      // - 참가자(createdBy/proUid/conUid)는 방을 자유롭게 업데이트 가능
      // - 비참가자는 "비어 있는 좌석"에 "자신의 uid"를 채워 입장하는 경우만 허용
      //   (점유된 좌석 가로채기 불가, 본인 외 uid 주입 불가)
      allow update: if request.auth != null && (
        request.auth.uid in [
          resource.data.createdBy,
          resource.data.proUid,
          resource.data.conUid
        ]
        || (resource.data.proUid == null && request.resource.data.proUid == request.auth.uid)
        || (resource.data.conUid == null && request.resource.data.conUid == request.auth.uid)
      );

      allow delete: if request.auth != null && resource.data.createdBy == request.auth.uid;

      match /messages/{messageId} {
        allow read: if true;
        allow create: if request.auth != null
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() < 2000;
        allow update, delete: if false;
      }

      match /votes/{uid} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == uid;
      }

      match /spectator_messages/{msgId} {
        allow read: if true;
        allow create: if request.auth != null
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() < 500;
        allow update, delete: if false;
      }
    }
  }
}
