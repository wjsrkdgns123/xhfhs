VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# 카카오톡 공유 — 카카오 개발자센터(developers.kakao.com)에서 앱 생성 후
# [앱 설정 > 플랫폼 > Web]에 https://ddatebattle.site 를 등록하고
# [앱 설정 > 앱 키]의 "JavaScript 키" 값을 붙여넣으세요.
# 비워두면 카카오 공유 대신 "링크 복사" fallback으로 동작합니다.
VITE_KAKAO_JS_KEY=

# Backend (Node)
ANTHROPIC_API_KEY=
PORT=3001

# 디자인 담당 GPT (OpenAI) — 팀의 디자인 역할(/디자인)을 GPT가 맡습니다.
# 디자인 판단(scripts/gpt-design.mjs judge) + 이미지 생성(image)에 사용.
# platform.openai.com 에서 발급한 sk-... 키. ※ ChatGPT 플러스 구독과는 별개의 유료 API 키입니다.
# 비워두면 디자인 "판단"은 수동(복붙) 모드로 가능하지만, 이미지 생성은 키가 반드시 필요합니다.
OPENAI_API_KEY=
# 디자인 "판단"용 채팅 모델 (선택, 기본 gpt-5.5).
OPENAI_MODEL=gpt-5.5
# 이미지 생성 모델 (선택, 기본 gpt-image-2). 다른 모델명을 쓰려면 여기서 교체.
OPENAI_IMAGE_MODEL=gpt-image-2
# 기본 이미지 화질 (선택, 기본 medium=중화질). low|medium|high — 고화질(high)은 운영자가 요청할 때만 사용.
OPENAI_IMAGE_QUALITY=medium
